WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here
WECHAT_API_BASE=https://api.weixin.qq.com
# File path to persist access_token across restarts; set to "" to disable.
WECHAT_TOKEN_CACHE_PATH=.wechat_token.json
# API key protecting /wechat/* and /mcp. Leave empty to disable auth (dev mode).
API_KEY=
API_KEY_HEADER=X-API-Key
HOST=0.0.0.0
PORT=8000
